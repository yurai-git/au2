{
  "editor.codeActionsOnSave": {
    "source.fixAll": "always",
    "source.removeUnusedImports": "always",
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "json",
    "jsonc",
    "markdown",
    "mdc",
    "dockerfile",
    "css",
    "scss",
    "less",
    "html",
    "vue",
    "svelte",
    "astro",
    "jinja",
    "twig",
    "nunjucks",
    "vento",
    "mustache",
    "xml",
    "yaml",
  ],
}
